{
  "manifest_version": 3,
  "name": "Page Cleaner",
  "version": "1.0",
  "description": "Removes distracting UI elements from article pages so you can read without clutter.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
